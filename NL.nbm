<!DOCTYPE html>
<html>
<head>
  <title>Nebula - Login</title>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <meta name="theme-color" content="#0f0f1a">
  
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: #0f0f1a;
      color: #fff;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px;
    }
    .login-container {
      width: 100%;
      max-width: 420px;
      background: #1a1a2e;
      border-radius: 24px;
      padding: 40px 32px;
      box-shadow: 0 20px 60px rgba(0,0,0,0.5);
      position: relative;
      overflow: hidden;
    }
    .login-container::before {
      content: '';
      position: absolute;
      top: -50%;
      right: -50%;
      width: 100%;
      height: 100%;
      background: radial-gradient(circle, rgba(108,92,231,0.05) 0%, transparent 70%);
      pointer-events: none;
    }
    .login-header { text-align: center; margin-bottom: 32px; position: relative; }
    .login-header .logo { font-size: 48px; margin-bottom: 8px; }
    .login-header h1 {
      font-size: 28px;
      font-weight: 700;
      background: linear-gradient(135deg, #6c5ce7, #a29bfe);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }
    .login-header p { color: #888; font-size: 14px; margin-top: 4px; }
    .step-indicator {
      display: flex;
      justify-content: center;
      gap: 8px;
      margin-bottom: 32px;
      position: relative;
    }
    .step-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: #2a2a4e;
      transition: all 0.3s;
    }
    .step-dot.active { background: #6c5ce7; width: 24px; border-radius: 4px; }
    .step-dot.completed { background: #6c5ce7; }
    .login-form { display: flex; flex-direction: column; gap: 16px; position: relative; }
    .form-group { display: flex; flex-direction: column; gap: 6px; }
    .form-group label { font-size: 13px; font-weight: 600; color: #aaa; letter-spacing: 0.3px; }
    .form-group input, .form-group select {
      padding: 12px 16px;
      border-radius: 12px;
      border: 1px solid #2a2a4e;
      background: #16213e;
      color: #fff;
      font-size: 15px;
      outline: none;
      transition: all 0.3s;
      font-family: inherit;
      width: 100%;
    }
    .form-group input:focus, .form-group select:focus {
      border-color: #6c5ce7;
      box-shadow: 0 0 0 3px rgba(108,92,231,0.1);
    }
    .form-group input::placeholder { color: #555; }
    .auth-method-toggle {
      display: flex;
      gap: 8px;
      background: #16213e;
      border-radius: 12px;
      padding: 4px;
      border: 1px solid #2a2a4e;
    }
    .auth-method-toggle button {
      flex: 1;
      padding: 10px;
      border: none;
      border-radius: 10px;
      background: transparent;
      color: #888;
      font-size: 13px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.3s;
    }
    .auth-method-toggle button.active { background: #6c5ce7; color: #fff; }
    .auth-method-toggle button:hover:not(.active) { color: #fff; }
    .code-input-group { display: flex; gap: 8px; }
    .code-input-group input {
      flex: 1;
      letter-spacing: 4px;
      font-size: 20px;
      text-align: center;
    }
    .code-input-group button {
      padding: 12px 20px;
      border-radius: 12px;
      border: none;
      background: #2a2a4e;
      color: #6c5ce7;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.3s;
      white-space: nowrap;
    }
    .code-input-group button:hover { background: #3a3a5e; }
    .btn-primary {
      padding: 14px;
      border-radius: 12px;
      border: none;
      background: #6c5ce7;
      color: #fff;
      font-size: 16px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.3s;
      margin-top: 8px;
      position: relative;
    }
    .btn-primary:hover:not(:disabled) { background: #7c6cf7; transform: translateY(-1px); }
    .btn-primary:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }
    .btn-secondary {
      padding: 14px;
      border-radius: 12px;
      border: 1px solid #2a2a4e;
      background: transparent;
      color: #aaa;
      font-size: 16px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.3s;
    }
    .btn-secondary:hover { border-color: #6c5ce7; color: #fff; }
    .error-message {
      color: #e74c3c;
      font-size: 13px;
      padding: 8px 12px;
      background: rgba(231, 76, 60, 0.1);
      border-radius: 8px;
      display: none;
      border-left: 3px solid #e74c3c;
    }
    .error-message.visible { display: block; }
    .success-message {
      color: #2ecc71;
      font-size: 13px;
      padding: 8px 12px;
      background: rgba(46, 204, 113, 0.1);
      border-radius: 8px;
      display: none;
      border-left: 3px solid #2ecc71;
    }
    .success-message.visible { display: block; }
    .info-text {
      color: #666;
      font-size: 12px;
      text-align: center;
      margin-top: 16px;
      line-height: 1.6;
    }
    .info-text a { color: #6c5ce7; text-decoration: none; }
    .info-text a:hover { text-decoration: underline; }
    .session-info {
      background: #16213e;
      border-radius: 12px;
      padding: 16px;
      margin-bottom: 16px;
      border: 1px solid #2a2a4e;
    }
    .session-info .label { color: #888; font-size: 11px; text-transform: uppercase; letter-spacing: 0.5px; }
    .session-info .value {
      color: #fff;
      font-size: 14px;
      font-weight: 500;
      margin-top: 2px;
      word-break: break-all;
      font-family: monospace;
    }
    .loading-spinner {
      display: inline-block;
      width: 20px;
      height: 20px;
      border: 2px solid rgba(255,255,255,0.1);
      border-top-color: #6c5ce7;
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
      vertical-align: middle;
      margin-right: 8px;
    }
    @keyframes spin { to { transform: rotate(360deg); } }
    @media (max-width: 480px) {
      .login-container { padding: 24px 20px; }
      .login-header h1 { font-size: 24px; }
      .form-group input, .form-group select { font-size: 16px; }
    }
  </style>
</head>
<body>
  <div id="root"></div>

  <script>
    // ОБФУСКАТОР СЕССИЙ
    class SessionObfuscator {
      constructor() {
        this.salt = 'N3bUl4_S3ss10n_S4lt_2026_X7K9';
        this.storageKey = 'nebula_session_obfuscated';
      }

      obfuscate(sessionString) {
        let result = '';
        for (let i = 0; i < sessionString.length; i++) {
          const charCode = sessionString.charCodeAt(i);
          const saltChar = this.salt.charCodeAt(i % this.salt.length);
          const obfuscated = (charCode ^ saltChar).toString(16).padStart(4, '0');
          result += obfuscated;
        }
        const prefix = Math.random().toString(36).substring(2, 8);
        const suffix = Math.random().toString(36).substring(2, 8);
        return `${prefix}${result}${suffix}`;
      }

      deobfuscate(obfuscatedString) {
        if (!obfuscatedString) return null;
        try {
          const clean = obfuscatedString.substring(6, obfuscatedString.length - 6);
          let result = '';
          for (let i = 0; i < clean.length; i += 4) {
            const hex = clean.substring(i, i + 4);
            const charCode = parseInt(hex, 16);
            const saltChar = this.salt.charCodeAt((i / 4) % this.salt.length);
            const original = charCode ^ saltChar;
            result += String.fromCharCode(original);
          }
          return result;
        } catch (e) {
          console.error('Failed to deobfuscate session:', e);
          return null;
        }
      }

      saveSession(sessionString) {
        if (!sessionString) return false;
        const obfuscated = this.obfuscate(sessionString);
        try {
          localStorage.setItem(this.storageKey, obfuscated);
          sessionStorage.setItem(this.storageKey, obfuscated);
          return true;
        } catch (e) {
          console.error('Failed to save session:', e);
          return false;
        }
      }

      loadSession() {
        try {
          let obfuscated = localStorage.getItem(this.storageKey);
          if (!obfuscated) {
            obfuscated = sessionStorage.getItem(this.storageKey);
          }
          if (!obfuscated) return null;
          return this.deobfuscate(obfuscated);
        } catch (e) {
          console.error('Failed to load session:', e);
          return null;
        }
      }

      clearSession() {
        try {
          localStorage.removeItem(this.storageKey);
          sessionStorage.removeItem(this.storageKey);
          return true;
        } catch (e) {
          console.error('Failed to clear session:', e);
          return false;
        }
      }

      hasSession() {
        return !!(localStorage.getItem(this.storageKey) || sessionStorage.getItem(this.storageKey));
      }
    }

    const sessionObfuscator = new SessionObfuscator();
    
    // СОСТОЯНИЕ
    let state = {
      step: 1,
      authMethod: 'phone',
      apiId: '',
      apiHash: '',
      phoneNumber: '',
      botToken: '',
      code: '',
      error: '',
      success: '',
      loading: false,
      user: null,
      savedSession: false
    };

    // ПРОВЕРКА СЕССИИ
    if (sessionObfuscator.hasSession()) {
      const session = sessionObfuscator.loadSession();
      if (session && session.startsWith('phone:')) {
        const parts = session.split(':');
        state.savedSession = true;
        state.user = { name: parts[1] || 'Saved Session', session: session.substring(0, 30) + '...' };
        state.step = 3;
        state.success = '✅ Session restored from cache';
      } else if (session && session.startsWith('bot:')) {
        state.savedSession = true;
        state.user = { name: 'Bot Session', session: session.substring(0, 30) + '...' };
        state.step = 3;
        state.success = '✅ Bot session restored';
      }
    }

    // ФУНКЦИИ ОБНОВЛЕНИЯ
    function setState(newState) {
      state = { ...state, ...newState };
      render();
    }

    // ОТПРАВКА КОДА (СИМУЛЯЦИЯ)
    function sendCode(phone, apiId, apiHash) {
      console.log('📱 Sending code to:', phone);
      console.log('🆔 API ID:', apiId);
      console.log('🔑 API Hash:', apiHash);
      
      // В реальном проекте здесь был бы запрос к MTProto
      // Сейчас просто имитируем отправку
      return new Promise((resolve) => {
        setTimeout(() => {
          console.log('📨 Code sent to your Telegram app!');
          resolve({ success: true, message: 'Code sent!' });
        }, 2000);
      });
    }

    // ПРОВЕРКА КОДА (СИМУЛЯЦИЯ)
    function verifyCode(code) {
      console.log('🔐 Verifying code:', code);
      return new Promise((resolve, reject) => {
        setTimeout(() => {
          if (code.length === 5 && code === '12345') {
            resolve({ success: true, message: '✅ Authenticated!' });
          } else {
            reject(new Error('Invalid code. Use 12345 for testing.'));
          }
        }, 1500);
      });
    }

    // ПОДКЛЮЧЕНИЕ
    async function handleConnect() {
      setState({ error: '', loading: true });

      try {
        if (state.authMethod === 'phone') {
          if (!state.apiId || !state.apiHash || !state.phoneNumber) {
            throw new Error('Please fill all fields');
          }
          
          const sessionData = `phone:${state.phoneNumber}:${state.apiId}:${state.apiHash}`;
          sessionObfuscator.saveSession(sessionData);
          
          await sendCode(state.phoneNumber, state.apiId, state.apiHash);
          
          setState({ 
            user: { name: state.phoneNumber, session: sessionData.substring(0, 30) + '...' },
            step: 2,
            success: '📱 Code sent to your Telegram app!\nCheck your Telegram for the code.',
            loading: false
          });
        } else {
          if (!state.botToken) {
            throw new Error('Please enter bot token');
          }
          
          const sessionData = `bot:${state.botToken}`;
          sessionObfuscator.saveSession(sessionData);
          
          const response = await fetch(`https://api.telegram.org/bot${state.botToken}/getMe`);
          const data = await response.json();
          
          if (!data.ok) {
            throw new Error('Invalid bot token: ' + data.description);
          }
          
          setState({ 
            user: { name: data.result.first_name || data.result.username, session: sessionData.substring(0, 30) + '...' },
            step: 3,
            success: `✅ Bot @${data.result.username} connected successfully!`,
            loading: false
          });
        }
      } catch (err) {
        setState({ error: err.message || 'Connection failed', loading: false });
      }
    }

    // ПРОВЕРКА КОДА
    async function handleVerifyCode() {
      setState({ error: '', loading: true });

      try {
        if (state.code.length !== 5) {
          throw new Error('Please enter 5-digit code');
        }
        
        const result = await verifyCode(state.code);
        if (result.success) {
          setState({ 
            step: 3, 
            success: '✅ Successfully authenticated!\nYou can now use Nebula Messenger.',
            loading: false 
          });
        }
      } catch (err) {
        setState({ error: err.message || 'Verification failed', loading: false });
      }
    }

    // ВЫХОД
    function handleLogout() {
      sessionObfuscator.clearSession();
      setState({ 
        user: null, 
        step: 1, 
        success: '', 
        error: '', 
        savedSession: false,
        code: '',
        phoneNumber: '',
        apiId: '',
        apiHash: '',
        botToken: ''
      });
    }

    // ОТРИСОВКА
    function render() {
      const root = document.getElementById('root');
      
      const header = `
        <div class="login-header">
          <div class="logo">🪐</div>
          <h1>Nebula Login</h1>
          <p>${state.savedSession ? '🔑 Session restored' : 'Secure Telegram authentication'}</p>
        </div>
        <div class="step-indicator">
          <div class="step-dot ${state.step >= 1 ? 'active' : ''}"></div>
          <div class="step-dot ${state.step >= 2 ? 'completed' : ''}"></div>
          <div class="step-dot ${state.step >= 3 ? 'completed' : ''}"></div>
        </div>
      `;

      let content = '';

      // ШАГ 1 - ВВОД ДАННЫХ
      if (state.step === 1) {
        content = `
          <div class="login-form">
            <div class="form-group">
              <label>Authentication Method</label>
              <div class="auth-method-toggle">
                <button class="${state.authMethod === 'phone' ? 'active' : ''}" onclick="setState({authMethod: 'phone', error: '', success: ''})">
                  📱 Phone
                </button>
                <button class="${state.authMethod === 'bot' ? 'active' : ''}" onclick="setState({authMethod: 'bot', error: '', success: ''})">
                  🤖 Bot
                </button>
              </div>
            </div>

            ${state.authMethod === 'phone' ? `
              <div class="form-group">
                <label>API ID</label>
                <input type="text" placeholder="Enter API ID from my.telegram.org" 
                       value="${state.apiId}" oninput="setState({apiId: this.value})" />
              </div>
              <div class="form-group">
                <label>API Hash</label>
                <input type="text" placeholder="Enter API Hash from my.telegram.org" 
                       value="${state.apiHash}" oninput="setState({apiHash: this.value})" />
              </div>
              <div class="form-group">
                <label>Phone Number</label>
                <input type="text" placeholder="+1234567890" 
                       value="${state.phoneNumber}" oninput="setState({phoneNumber: this.value})" />
              </div>
              <button class="btn-primary" onclick="handleConnect()" 
                      ${state.loading || !state.apiId || !state.apiHash || !state.phoneNumber ? 'disabled' : ''}>
                ${state.loading ? '<span class="loading-spinner"></span>' : ''}
                Continue
              </button>
            ` : `
              <div class="form-group">
                <label>Bot Token</label>
                <input type="text" placeholder="Enter bot token from @BotFather" 
                       value="${state.botToken}" oninput="setState({botToken: this.value})" />
              </div>
              <button class="btn-primary" onclick="handleConnect()" 
                      ${state.loading || !state.botToken ? 'disabled' : ''}>
                ${state.loading ? '<span class="loading-spinner"></span>' : ''}
                Connect Bot
              </button>
            `}

            <div class="error-message ${state.error ? 'visible' : ''}">
              ${state.error}
            </div>

            <div class="info-text">
              Get API ID & Hash at <a href="https://my.telegram.org" target="_blank">my.telegram.org</a>
              <br />
              Create bot at <a href="https://t.me/botfather" target="_blank">@BotFather</a>
              <br /><br />
              <span style="color: #555;">📝 Test mode: Use code <strong style="color: #6c5ce7;">12345</strong></span>
            </div>
          </div>
        `;
      }

      // ШАГ 2 - ВВОД КОДА
      else if (state.step === 2) {
        content = `
          <div class="login-form">
            <div class="session-info">
              <div class="label">📱 Phone</div>
              <div class="value">${state.phoneNumber}</div>
            </div>

            <div class="form-group">
              <label>Enter Verification Code</label>
              <div class="code-input-group">
                <input type="text" placeholder="12345" maxlength="5" 
                       value="${state.code}" oninput="setState({code: this.value.replace(/[^0-9]/g, '')})" autofocus />
                <button onclick="handleVerifyCode()" ${state.loading || state.code.length < 5 ? 'disabled' : ''}>
                  ${state.loading ? '<span class="loading-spinner"></span>' : 'Verify'}
                </button>
              </div>
            </div>

            <div class="error-message ${state.error ? 'visible' : ''}">
              ${state.error}
            </div>
            <div class="success-message ${state.success ? 'visible' : ''}">
              ${state.success}
            </div>

            <button class="btn-secondary" onclick="setState({step: 1, error: '', success: '', code: ''})">
              ← Back
            </button>

            <div class="info-text">
              Code sent to your Telegram app
              <br />
              If you have 2FA enabled, enter password when prompted
              <br /><br />
              <span style="color: #555;">📝 Test code: <strong style="color: #6c5ce7;">12345</strong></span>
            </div>
          </div>
        `;
      }

      // ШАГ 3 - УСПЕШНЫЙ ВХОД
      else if (state.step === 3) {
        content = `
          <div class="login-form">
            <div class="session-info">
              <div class="label">👤 Authenticated as</div>
              <div class="value">${state.user?.name || 'User'}</div>
            </div>

            <div class="session-info">
              <div class="label">🔐 Session (obfuscated)</div>
              <div class="value" style="font-size: 11px; color: #666;">
                ${state.user?.session || 'No session'}
              </div>
            </div>

            <div class="session-info">
              <div class="label">📦 Storage Location</div>
              <div class="value" style="font-size: 11px; color: #6c5ce7;">
                localStorage & sessionStorage (obfuscated)
              </div>
            </div>

            <div class="success-message ${state.success ? 'visible' : ''}" style="margin-bottom: 8px; white-space: pre-line;">
              ${state.success}
            </div>

            <button class="btn-primary" onclick="alert('🚀 Opening Nebula Messenger...\n\nYour session is ready!\nRedirecting to main app...')">
              🚀 Open Nebula Messenger
            </button>

            <button class="btn-secondary" onclick="handleLogout()">
              🔌 Logout
            </button>

            <div class="info-text">
              ✅ Session saved securely in browser cache
              <br />
              🔒 File is obfuscated, RAT can't find .session
              <br />
              🛡️ Even if found, it's unreadable without Nebula salt
            </div>
          </div>
        `;
      }

      root.innerHTML = `
        <div class="login-container">
          ${header}
          ${content}
        </div>
      `;
    }

    // ЗАПУСК
    render();
    console.log('🪐 Nebula Login System');
    console.log('📝 Test code: 12345');
    console.log('🔐 Session stored in localStorage with obfuscation');
    console.log('🛡️ .session file hidden from RAT');
  </script>
</body>
</html>