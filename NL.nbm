<!DOCTYPE html>
<html>
<head>
  <title>Nebula - Login</title>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <meta name="theme-color" content="#0f0f1a">
  
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: #0f0f1a;
      color: #fff;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px;
    }
    .login-container {
      width: 100%;
      max-width: 420px;
      background: #1a1a2e;
      border-radius: 24px;
      padding: 40px 32px;
      box-shadow: 0 20px 60px rgba(0,0,0,0.5);
      position: relative;
      overflow: hidden;
    }
    .login-container::before {
      content: '';
      position: absolute;
      top: -50%;
      right: -50%;
      width: 100%;
      height: 100%;
      background: radial-gradient(circle, rgba(108,92,231,0.05) 0%, transparent 70%);
      pointer-events: none;
    }
    .login-header { text-align: center; margin-bottom: 32px; position: relative; }
    .login-header .logo { font-size: 48px; margin-bottom: 8px; }
    .login-header h1 {
      font-size: 28px;
      font-weight: 700;
      background: linear-gradient(135deg, #6c5ce7, #a29bfe);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }
    .login-header p { color: #888; font-size: 14px; margin-top: 4px; }
    .step-indicator {
      display: flex;
      justify-content: center;
      gap: 8px;
      margin-bottom: 32px;
    }
    .step-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: #2a2a4e;
      transition: all 0.3s;
    }
    .step-dot.active { background: #6c5ce7; width: 24px; border-radius: 4px; }
    .step-dot.completed { background: #6c5ce7; }
    .login-form { display: flex; flex-direction: column; gap: 16px; }
    .form-group { display: flex; flex-direction: column; gap: 6px; }
    .form-group label { font-size: 13px; font-weight: 600; color: #aaa; letter-spacing: 0.3px; }
    .form-group input {
      padding: 12px 16px;
      border-radius: 12px;
      border: 1px solid #2a2a4e;
      background: #16213e;
      color: #fff;
      font-size: 15px;
      outline: none;
      transition: all 0.3s;
      font-family: inherit;
      width: 100%;
    }
    .form-group input:focus { border-color: #6c5ce7; box-shadow: 0 0 0 3px rgba(108,92,231,0.1); }
    .form-group input::placeholder { color: #555; }
    .auth-method-toggle {
      display: flex;
      gap: 8px;
      background: #16213e;
      border-radius: 12px;
      padding: 4px;
      border: 1px solid #2a2a4e;
    }
    .auth-method-toggle button {
      flex: 1;
      padding: 10px;
      border: none;
      border-radius: 10px;
      background: transparent;
      color: #888;
      font-size: 13px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.3s;
    }
    .auth-method-toggle button.active { background: #6c5ce7; color: #fff; }
    .auth-method-toggle button:hover:not(.active) { color: #fff; }
    .code-input-group { display: flex; gap: 8px; }
    .code-input-group input {
      flex: 1;
      letter-spacing: 4px;
      font-size: 20px;
      text-align: center;
    }
    .code-input-group button {
      padding: 12px 20px;
      border-radius: 12px;
      border: none;
      background: #2a2a4e;
      color: #6c5ce7;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.3s;
      white-space: nowrap;
    }
    .code-input-group button:hover { background: #3a3a5e; }
    .btn-primary {
      padding: 14px;
      border-radius: 12px;
      border: none;
      background: #6c5ce7;
      color: #fff;
      font-size: 16px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.3s;
      margin-top: 8px;
    }
    .btn-primary:hover:not(:disabled) { background: #7c6cf7; transform: translateY(-1px); }
    .btn-primary:disabled { opacity: 0.5; cursor: not-allowed; }
    .btn-secondary {
      padding: 14px;
      border-radius: 12px;
      border: 1px solid #2a2a4e;
      background: transparent;
      color: #aaa;
      font-size: 16px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.3s;
    }
    .btn-secondary:hover { border-color: #6c5ce7; color: #fff; }
    .error-message {
      color: #e74c3c;
      font-size: 13px;
      padding: 8px 12px;
      background: rgba(231, 76, 60, 0.1);
      border-radius: 8px;
      display: none;
      border-left: 3px solid #e74c3c;
    }
    .error-message.visible { display: block; }
    .success-message {
      color: #2ecc71;
      font-size: 13px;
      padding: 8px 12px;
      background: rgba(46, 204, 113, 0.1);
      border-radius: 8px;
      display: none;
      border-left: 3px solid #2ecc71;
    }
    .success-message.visible { display: block; }
    .info-text {
      color: #666;
      font-size: 12px;
      text-align: center;
      margin-top: 16px;
      line-height: 1.6;
    }
    .info-text a { color: #6c5ce7; text-decoration: none; }
    .info-text a:hover { text-decoration: underline; }
    .session-info {
      background: #16213e;
      border-radius: 12px;
      padding: 16px;
      margin-bottom: 16px;
      border: 1px solid #2a2a4e;
    }
    .session-info .label { color: #888; font-size: 11px; text-transform: uppercase; letter-spacing: 0.5px; }
    .session-info .value {
      color: #fff;
      font-size: 14px;
      font-weight: 500;
      margin-top: 2px;
      word-break: break-all;
      font-family: monospace;
    }
    .loading-spinner {
      display: inline-block;
      width: 20px;
      height: 20px;
      border: 2px solid rgba(255,255,255,0.1);
      border-top-color: #6c5ce7;
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
      vertical-align: middle;
      margin-right: 8px;
    }
    @keyframes spin { to { transform: rotate(360deg); } }
    .restore-notice {
      background: rgba(108,92,231,0.12);
      border: 1px solid #6c5ce7;
      border-radius: 10px;
      padding: 10px 14px;
      margin-bottom: 16px;
      text-align: center;
      color: #a29bfe;
      font-size: 13px;
      display: none;
    }
    .restore-notice.visible { display: block; }
    @media (max-width: 480px) {
      .login-container { padding: 24px 20px; }
      .login-header h1 { font-size: 24px; }
      .form-group input { font-size: 16px; }
    }
  </style>
</head>
<body>
  <div id="root"></div>

  <script>
    class SessionObfuscator {
      constructor() {
        this.salt = 'N3bUl4_S3ss10n_S4lt_2026_X7K9';
        this.storageKey = 'nebula_session_obfuscated';
      }
      obfuscate(s) {
        let r = '';
        for (let i = 0; i < s.length; i++) {
          const c = s.charCodeAt(i);
          const salt = this.salt.charCodeAt(i % this.salt.length);
          r += (c ^ salt).toString(16).padStart(4, '0');
        }
        const p = Math.random().toString(36).substring(2, 8);
        const suf = Math.random().toString(36).substring(2, 8);
        return p + r + suf;
      }
      deobfuscate(s) {
        if (!s) return null;
        try {
          const clean = s.substring(6, s.length - 6);
          let r = '';
          for (let i = 0; i < clean.length; i += 4) {
            const hex = clean.substring(i, i + 4);
            const c = parseInt(hex, 16);
            const salt = this.salt.charCodeAt((i / 4) % this.salt.length);
            r += String.fromCharCode(c ^ salt);
          }
          return r;
        } catch (e) { return null; }
      }
      saveSession(s) {
        if (!s) return false;
        try {
          const o = this.obfuscate(s);
          localStorage.setItem(this.storageKey, o);
          sessionStorage.setItem(this.storageKey, o);
          return true;
        } catch (e) { return false; }
      }
      loadSession() {
        try {
          let o = localStorage.getItem(this.storageKey);
          if (!o) o = sessionStorage.getItem(this.storageKey);
          if (!o) return null;
          return this.deobfuscate(o);
        } catch (e) { return null; }
      }
      clearSession() {
        try {
          localStorage.removeItem(this.storageKey);
          sessionStorage.removeItem(this.storageKey);
          return true;
        } catch (e) { return false; }
      }
      hasSession() {
        return !!(localStorage.getItem(this.storageKey) || sessionStorage.getItem(this.storageKey));
      }
    }

    const so = new SessionObfuscator();
    let state = {
      step: 1,
      authMethod: 'phone',
      apiId: '',
      apiHash: '',
      phoneNumber: '',
      botToken: '',
      code: '',
      error: '',
      success: '',
      loading: false,
      user: null,
      sessionRestored: false
    };

    function setState(newState) {
      state = { ...state, ...newState };
      render();
    }

    function checkSession() {
      const s = so.loadSession();
      if (s) {
        if (s.startsWith('phone:')) {
          const parts = s.split(':');
          state.user = { name: parts[1] || 'User', session: s.substring(0, 30) + '...', method: 'phone' };
          state.step = 3;
          state.success = '✅ Сессия восстановлена';
          state.sessionRestored = true;
        } else if (s.startsWith('bot:')) {
          const token = s.substring(4);
          state.user = { name: 'Bot', session: s.substring(0, 30) + '...', method: 'bot' };
          state.step = 3;
          state.success = '✅ Сессия бота восстановлена';
          state.sessionRestored = true;
          fetch(`https://api.telegram.org/bot${token}/getMe`)
            .then(r => r.json())
            .then(d => { if (d.ok) { state.user.name = d.result.first_name || d.result.username; render(); } })
            .catch(() => {});
        }
        return true;
      }
      return false;
    }

    async function handleConnect() {
      setState({ error: '', loading: true });
      try {
        if (state.authMethod === 'phone') {
          if (!state.apiId || !state.apiHash || !state.phoneNumber) throw new Error('Заполните все поля');
          const sd = `phone:${state.phoneNumber}:${state.apiId}:${state.apiHash}`;
          so.saveSession(sd);
          await new Promise(r => setTimeout(r, 1500));
          setState({
            user: { name: state.phoneNumber, session: sd.substring(0, 30) + '...', method: 'phone' },
            step: 2,
            success: '📱 Код отправлен в Telegram!',
            loading: false
          });
        } else {
          if (!state.botToken) throw new Error('Введите токен бота');
          const sd = `bot:${state.botToken}`;
          so.saveSession(sd);
          const resp = await fetch(`https://api.telegram.org/bot${state.botToken}/getMe`);
          const data = await resp.json();
          if (!data.ok) throw new Error('Неверный токен: ' + data.description);
          setState({
            user: { name: data.result.first_name || data.result.username, session: sd.substring(0, 30) + '...', method: 'bot' },
            step: 3,
            success: `✅ Бот @${data.result.username} подключён!`,
            loading: false
          });
        }
      } catch (err) {
        setState({ error: err.message, loading: false });
      }
    }

    async function handleVerifyCode() {
      setState({ error: '', loading: true });
      try {
        if (state.code.length !== 5) throw new Error('Введите 5-значный код');
        await new Promise(r => setTimeout(r, 1500));
        if (state.code === '12345') {
          setState({ step: 3, success: '✅ Успешная авторизация!', loading: false });
        } else {
          throw new Error('Неверный код. Используйте 12345 для теста.');
        }
      } catch (err) {
        setState({ error: err.message, loading: false });
      }
    }

    function handleLogout() {
      so.clearSession();
      setState({
        user: null, step: 1, success: '', error: '', sessionRestored: false,
        code: '', phoneNumber: '', apiId: '', apiHash: '', botToken: ''
      });
    }

    function continueToNebula() {
      sessionStorage.setItem('nebula_logged_in', 'true');
      window.location.href = 'index.html';
    }

    function render() {
      const root = document.getElementById('root');
      const header = `
        <div class="login-header">
          <div class="logo">🪐</div>
          <h1>Nebula Login</h1>
          <p>${state.sessionRestored ? '🔑 Сессия восстановлена' : 'Безопасная авторизация'}</p>
        </div>
        <div class="step-indicator">
          <div class="step-dot ${state.step >= 1 ? 'active' : ''}"></div>
          <div class="step-dot ${state.step >= 2 ? 'completed' : ''}"></div>
          <div class="step-dot ${state.step >= 3 ? 'completed' : ''}"></div>
        </div>
      `;

      let content = '';
      const restoreNotice = `
        <div class="restore-notice ${state.sessionRestored ? 'visible' : ''}">
          🔑 Сессия восстановлена из кэша
        </div>
      `;

      if (state.step === 1) {
        content = `
          <div class="login-form">
            ${restoreNotice}
            <div class="form-group">
              <label>Метод авторизации</label>
              <div class="auth-method-toggle">
                <button class="${state.authMethod === 'phone' ? 'active' : ''}" onclick="setState({authMethod: 'phone', error: '', success: ''})">📱 Телефон</button>
                <button class="${state.authMethod === 'bot' ? 'active' : ''}" onclick="setState({authMethod: 'bot', error: '', success: ''})">🤖 Бот</button>
              </div>
            </div>
            ${state.authMethod === 'phone' ? `
              <div class="form-group"><label>API ID</label><input type="text" placeholder="API ID с my.telegram.org" value="${state.apiId}" oninput="setState({apiId: this.value})" /></div>
              <div class="form-group"><label>API Hash</label><input type="text" placeholder="API Hash с my.telegram.org" value="${state.apiHash}" oninput="setState({apiHash: this.value})" /></div>
              <div class="form-group"><label>Номер телефона</label><input type="text" placeholder="+1234567890" value="${state.phoneNumber}" oninput="setState({phoneNumber: this.value})" /></div>
              <button class="btn-primary" onclick="handleConnect()" ${state.loading || !state.apiId || !state.apiHash || !state.phoneNumber ? 'disabled' : ''}>
                ${state.loading ? '<span class="loading-spinner"></span>' : ''} Продолжить
              </button>
            ` : `
              <div class="form-group"><label>Токен бота</label><input type="text" placeholder="Токен от @BotFather" value="${state.botToken}" oninput="setState({botToken: this.value})" /></div>
              <button class="btn-primary" onclick="handleConnect()" ${state.loading || !state.botToken ? 'disabled' : ''}>
                ${state.loading ? '<span class="loading-spinner"></span>' : ''} Подключить бота
              </button>
            `}
            <div class="error-message ${state.error ? 'visible' : ''}">${state.error}</div>
            <div class="info-text">
              API ID & Hash: <a href="https://my.telegram.org" target="_blank">my.telegram.org</a><br>
              Создать бота: <a href="https://t.me/botfather" target="_blank">@BotFather</a><br><br>
              <span style="color:#555;">📝 Тестовый код: <strong style="color:#6c5ce7;">12345</strong></span>
            </div>
          </div>
        `;
      } else if (state.step === 2) {
        content = `
          <div class="login-form">
            <div class="session-info"><div class="label">📱 Телефон</div><div class="value">${state.phoneNumber}</div></div>
            <div class="form-group">
              <label>Код подтверждения</label>
              <div class="code-input-group">
                <input type="text" placeholder="12345" maxlength="5" value="${state.code}" oninput="setState({code: this.value.replace(/[^0-9]/g, '')})" autofocus />
                <button onclick="handleVerifyCode()" ${state.loading || state.code.length < 5 ? 'disabled' : ''}>
                  ${state.loading ? '<span class="loading-spinner"></span>' : 'Проверить'}
                </button>
              </div>
            </div>
            <div class="error-message ${state.error ? 'visible' : ''}">${state.error}</div>
            <div class="success-message ${state.success ? 'visible' : ''}">${state.success}</div>
            <button class="btn-secondary" onclick="setState({step: 1, error: '', success: '', code: ''})">← Назад</button>
            <div class="info-text">📝 Тестовый код: <strong style="color:#6c5ce7;">12345</strong></div>
          </div>
        `;
      } else if (state.step === 3) {
        content = `
          <div class="login-form">
            <div class="session-info"><div class="label">👤 Пользователь</div><div class="value">${state.user?.name || 'User'}</div></div>
            <div class="session-info"><div class="label">🔐 Сессия</div><div class="value" style="font-size:11px;color:#666;">${state.user?.session || 'Нет сессии'}</div></div>
            <div class="session-info"><div class="label">📦 Хранилище</div><div class="value" style="font-size:11px;color:#6c5ce7;">localStorage (обфусцировано)</div></div>
            <div class="success-message ${state.success ? 'visible' : ''}" style="margin-bottom:8px;white-space:pre-line;">${state.success}</div>
            <button class="btn-primary" onclick="continueToNebula()">🚀 Открыть Nebula</button>
            <button class="btn-secondary" onclick="handleLogout()">🔌 Выйти</button>
            <div class="info-text">✅ Сессия сохранена в кэше браузера<br>🔒 Файл обфусцирован, RAT не найдёт .session</div>
          </div>
        `;
      }

      root.innerHTML = `<div class="login-container">${header}${content}</div>`;
    }

    checkSession();
    render();
    console.log('🪐 Nebula Login v2.0');
    console.log('📱 Поддержка: телефон и бот');
    console.log('📝 Тестовый код: 12345');
    console.log('🔐 Сессия обфусцирована');
  </script>
</body>
</html>